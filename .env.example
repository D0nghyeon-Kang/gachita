# 서버 설정
PORT=3000
NODE_ENV=development

# JWT 인증
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# DB 경로 (SQLite)
DB_PATH=./db/gachita.db

# 클라이언트 URL (CORS 허용)
CLIENT_URL=http://localhost:5173

# 네이버 클라우드 플랫폼 Maps API
# 발급 완료 (2026-05-29) 
# console.ncloud.com/maps/application 에서 'gachita' Application 확인
# 실제 키값은 톡방에 올리겠습니다!!
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=